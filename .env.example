# Системный промпт ассистента: задаёт стиль, язык и базовые ограничения ответа.
SYSTEM_PROMPT="Ты — ИИ-ассистент Джассея. Отвечай только на русском, чётко и по делу.\nНикаких других языков, кроме русского (кроме кода и терминов).\nЕсли не знаешь — скажи честно. На неэтичные запросы корректно откажи."

# Промпт архивариуса: определяет формат и правила извлечения фактов в JSON.
SUMMARY_PROMPT="Ты Архивариус памяти.\nВерни ТОЛЬКО JSON вида {{\"facts\":[\"...\"]}}.\nЕсли фактов нет: {{\"facts\":[]}}.\nПравила:\n1) Не выдумывай. Бери только из сообщения user.\n2) Каждый факт должен быть сформулирован строго относительно пользователя (его целей, предпочтений, решений, действий, информации о пользователе и т.д.).\n3) 1 факт = 1 короткая строка.\n4) Сохраняй только полезное надолго: предпочтения пользователя, постоянные данные пользователя, цели пользователя, договоренности пользователя, ограничения для пользователя.\n5) Факты из строк A: НЕ используй, за исключением явного подтверждения фактов, уже сказанных в строках U:. Строки A: не должны становиться источником новых фактов, только подтверждать факты от U:.\n6) Удаляй дубли и шум.\n7) Пиши по-русски.\n8) Максимум {max_facts} фактов.\n9) Никакого текста вне JSON.\n"

# Промпт judge-модуля: решает, как соотнести новый факт со старым.
FACT_JUDGE_PROMPT="Сравни старый и новый факт.\nОпредели отношение: новый факт заменяет старый, дополняет его или это одно и то же.\nОтветь одним словом: REPLACE, ADD или IGNORE.\nБери данные только из сообщения user."

# Размер окна сообщений, после которого запускается суммаризация памяти.
SUMMARY_EVERY_N_MESSAGES=8
# Максимум фактов, которые архивариус может вернуть за один batch.
SUMMARY_MAX_FACTS=7
# Лимит простого поиска фактов (legacy-параметр, если где-то используется напрямую).
MEMORY_SEARCH_LIMIT=10
# Нижний порог похожести: ниже этого факты считаются недостаточно близкими.
FACT_SIMILARITY_LOW=0.8
# Верхний порог похожести: выше этого факты считаются почти идентичными.
FACT_SIMILARITY_HIGH=0.95

# Модель judge-агента для принятия решений по конфликтующим фактам.
FACT_JUDGE_MODEL=qwen2.5:1.5b-instruct
# Базовая модель ассистента для генерации ответа пользователю.
BASE_MODEL=qwen-8k:latest
# Температура базовой модели: ниже значение — более стабильные ответы.
BASE_MODEL_TEMPERATURE=0.1
# top_k базовой модели: ограничивает набор токенов-кандидатов на шаге генерации.
BASE_MODEL_TOP_K=40
# top_p базовой модели: ограничивает "ядро" вероятностного распределения токенов.
BASE_MODEL_TOP_P=0.85

# URL API LLM-провайдера (локальный или удалённый endpoint совместимого API).
LLM_BASE_URL=http://localhost:11434/v1
# API-ключ LLM-провайдера.
LLM_API_KEY=ollama
# Хост Qdrant, где хранится долговременная память.
QDRANT_HOST=localhost
# Порт Qdrant.
QDRANT_PORT=6333

# Таймаут judge-вызова в секундах, чтобы не блокировать pipeline слишком долго.
FACT_JUDGE_TIMEOUT_SEC=20
# Флаг подробных логов memory pipeline для диагностики и отладки.
MEMORY_PIPELINE_LOGS_ENABLED=true
# Температура архивариуса при суммаризации диалога в факты.
ARCHIVIST_TEMPERATURE=0.1
# Температура judge-модуля (обычно 0 для детерминированных решений).
FACT_JUDGE_TEMPERATURE=0.0

# Минимальный score векторного поиска, чтобы факт считался релевантным.
MEMORY_MIN_VECTOR_SCORE=0.72
# Модель rerank-агента для дополнительной переоценки релевантности фактов.
MEMORY_RERANK_MODEL=qwen2.5:1.5b-instruct
# Температура rerank-модуля.
MEMORY_RERANK_TEMPERATURE=0.0
# Вес rerank-оценки в финальном скоринге фактов.
MEMORY_RERANK_WEIGHT=0.6
# Вес исходного векторного score в финальном скоринге фактов.
MEMORY_VECTOR_WEIGHT=0.4

# Сколько кандидатов максимально брать из векторного поиска перед rerank.
MEMORY_RETRIEVAL_TOP_K=20
# Сколько фактов оставлять после rerank-этапа.
MEMORY_RERANK_TOP_N=6
# Сколько фактов максимум добавлять в системный контекст ответа.
MEMORY_CONTEXT_FACTS_LIMIT=4
# Включатель rerank-этапа: при False используется только векторный score.
MEMORY_RERANK_ENABLED=true
